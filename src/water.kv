#:kivy 2.0.0

<WaterCalculatorScreen>:
    name: 'water_calc'
    BoxLayout:
        orientation: 'vertical'
        padding: 5
        spacing: 5
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # HEADER
        BoxLayout:
            size_hint_y: None
            height: '40dp'
            padding: [10, 0]
            Label:
                text: "WaterBrain Calculator"
                font_size: '22sp'
                bold: True
                color: 0.2, 0.6, 1, 1
                halign: 'left'
                text_size: self.size
                valign: 'middle'

        # TABS
        TabbedPanel:
            id: tabs
            do_default_tab: False
            tab_width: self.parent.width / 3
            background_color: 0.1, 0.1, 0.1, 1
            
            # --- TAB 1: WATER (Renamed & No Button) ---
            TabbedPanelItem:
                text: "WATER"
                GridLayout:
                    cols: 2
                    padding: 5
                    spacing: 10
                    
                    # --- COLUMN 0 (Left) ---
                    BoxLayout:
                        orientation: 'vertical'
                        spacing: 5
                        
                        # 1. Mash Method
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Method"
                                size_hint_x: 0.35
                                font_size: '14sp'
                            Spinner:
                                text: root.mash_method
                                values: ["No Sparge (BIAB)", "Sparge"]
                                on_text: root.mash_method = self.text
                                size_hint_x: 0.65
                                background_color: 0.2, 0.4, 0.6, 1

                        # 2. Grain Weight
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Grain"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 2.0
                                max: 15.0
                                step: 0.5
                                value: root.grain_wt
                                on_value: root.grain_wt = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{root.grain_wt} {'kg' if root.is_metric else 'lb'}"
                                size_hint_x: 0.2
                                font_size: '14sp'

                        # 3. Grain Temp
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Grain"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 50
                                max: 80
                                step: 1
                                value: root.grain_temp
                                on_value: root.grain_temp = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{int(root.grain_temp)} {'C' if root.is_metric else 'F'}"
                                size_hint_x: 0.2
                                font_size: '14sp'

                        # 4. Mash Temp
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Mash"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 145
                                max: 165
                                step: 1
                                value: root.mash_temp
                                on_value: root.mash_temp = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{int(root.mash_temp)} {'C' if root.is_metric else 'F'}"
                                size_hint_x: 0.2
                                font_size: '14sp'

                        # 5. Boil Time
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Boil Time"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 30
                                max: 120
                                step: 15
                                value: root.boil_time
                                on_value: root.boil_time = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{int(root.boil_time)} min"
                                size_hint_x: 0.2
                                font_size: '14sp'

                        # 6. Into Fermenter
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Into Fermenter"
                                text_size: self.size
                                halign: 'right'
                                valign: 'middle'
                                padding_x: 10
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 2.0
                                max: 8.0
                                step: 0.5
                                value: root.ferm_vol
                                on_value: root.ferm_vol = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{root.ferm_vol} {'L' if root.is_metric else 'G'}"
                                size_hint_x: 0.2
                                font_size: '14sp'

                    # --- COLUMN 1 (Right) ---
                    BoxLayout:
                        orientation: 'vertical'
                        spacing: 5

                        # 1. Unit Spinner
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Units"
                                size_hint_x: 0.35
                                font_size: '14sp'
                            Spinner:
                                text: "Metric" if root.is_metric else "US Std"
                                values: ["US Std", "Metric"]
                                on_text: root.update_units(self.text)
                                size_hint_x: 0.65
                                background_color: 0.2, 0.4, 0.6, 1

                        # 2. Absorption
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Absorption"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 0.20
                                max: 1.20
                                step: 0.05
                                value: root.abs_rate
                                on_value: root.abs_rate = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{root.abs_rate:.2f} {'L/kg' if root.is_metric else 'qt/lb'}"
                                size_hint_x: 0.2
                                font_size: '14sp'

                        # 3. Thickness
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Thickness"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 0.5
                                max: 3.0
                                step: 0.1
                                value: root.thickness
                                disabled: root.mash_method == "No Sparge (BIAB)"
                                on_value: root.thickness = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{root.thickness:.1f} {'L/kg' if root.is_metric else 'qt/lb'}"
                                color: (1,1,1,1) if root.mash_method == "Sparge" else (0.4,0.4,0.4,1)
                                size_hint_x: 0.2
                                font_size: '14sp'

                        # 4. Boil Off
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Boil Off"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 0.5
                                max: 3.5
                                step: 0.1
                                value: root.boiloff
                                on_value: root.boiloff = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{root.boiloff:.1f} {'L/h' if root.is_metric else 'G/h'}"
                                size_hint_x: 0.2
                                font_size: '14sp'

                        # 5. Trub Loss
                        BoxLayout:
                            size_hint_y: 1
                            Label: 
                                text: "Trub"
                                size_hint_x: 0.3
                                font_size: '14sp'
                            Slider:
                                min: 0.0
                                max: 3.0
                                step: 0.25
                                value: root.trub_vol
                                on_value: root.trub_vol = self.value
                                size_hint_x: 0.5
                            Label:
                                text: f"{root.trub_vol:.2f} {'L' if root.is_metric else 'G'}"
                                size_hint_x: 0.2
                                font_size: '14sp'
                        
                        # FILLER WIDGET (Since button is gone)
                        Widget:

            # --- TAB 2: CHEMISTRY (Final Polish) ---
            TabbedPanelItem:
                text: "CHEMISTRY"
                BoxLayout:
                    orientation: 'vertical'
                    padding: 20
                    spacing: 10

                    # --- TOP SECTION (Grid) ---
                    GridLayout:
                        cols: 2
                        spacing: 20
                        size_hint_y: 0.5

                        # COLUMN 0 (Left)
                        BoxLayout:
                            orientation: 'vertical'
                            spacing: 20  # <--- INCREASED from 10 to 20
                            
                            # 1. Profile Spinner
                            BoxLayout:
                                size_hint_y: 1
                                Label: 
                                    text: "Profile"
                                    size_hint_x: 0.3
                                    font_size: '14sp'
                                Spinner:
                                    text: "Select..."
                                    values: root.profile_names
                                    on_text: root.load_target_profile(self.text)
                                    size_hint_x: 0.7
                                    background_color: 0.2, 0.4, 0.6, 1

                            # 2. Beer SRM
                            BoxLayout:
                                size_hint_y: 1
                                Label: 
                                    text: "SRM"
                                    size_hint_x: 0.3
                                    font_size: '14sp'
                                Slider:
                                    min: 1
                                    max: 40
                                    step: 1
                                    value: root.srm
                                    on_value: root.srm = self.value
                                    size_hint_x: 0.5
                                Label:
                                    text: str(int(root.srm))
                                    size_hint_x: 0.2
                                    font_size: '14sp'

                            # 3. Calcium (Ca)
                            BoxLayout:
                                size_hint_y: 1
                                Label: 
                                    text: "Ca"
                                    size_hint_x: 0.3
                                    font_size: '14sp'
                                    bold: True
                                    color: 0.6, 0.6, 0.6, 1
                                Slider:
                                    min: 0
                                    max: 200
                                    step: 5
                                    value: root.tgt_ca
                                    on_value: root.tgt_ca = self.value
                                    size_hint_x: 0.5
                                Label:
                                    text: str(int(root.tgt_ca))
                                    size_hint_x: 0.2
                                    font_size: '14sp'

                        # COLUMN 1 (Right)
                        BoxLayout:
                            orientation: 'vertical'
                            spacing: 20  # <--- INCREASED from 10 to 20

                            # 1. Target pH
                            BoxLayout:
                                size_hint_y: 1
                                Label: 
                                    text: "Est pH"
                                    size_hint_x: 0.3
                                    font_size: '14sp'
                                Slider:
                                    min: 5.1
                                    max: 5.8
                                    step: 0.05
                                    value: root.target_ph
                                    on_value: root.target_ph = self.value
                                    size_hint_x: 0.5
                                Label:
                                    text: f"{root.target_ph:.2f}"
                                    size_hint_x: 0.2
                                    font_size: '14sp'

                            # 2. Magnesium (Mg)
                            BoxLayout:
                                size_hint_y: 1
                                Label: 
                                    text: "Mg"
                                    size_hint_x: 0.3
                                    font_size: '14sp'
                                    color: 0.6, 0.6, 0.6, 1
                                Slider:
                                    min: 0
                                    max: 50
                                    step: 1
                                    value: root.tgt_mg
                                    on_value: root.tgt_mg = self.value
                                    size_hint_x: 0.5
                                Label:
                                    text: str(int(root.tgt_mg))
                                    size_hint_x: 0.2
                                    font_size: '14sp'

                            # 3. Sodium (Na)
                            BoxLayout:
                                size_hint_y: 1
                                Label: 
                                    text: "Na"
                                    size_hint_x: 0.3
                                    font_size: '14sp'
                                    color: 0.6, 0.6, 0.6, 1
                                Slider:
                                    min: 0
                                    max: 100
                                    step: 5
                                    value: root.tgt_na
                                    on_value: root.tgt_na = self.value
                                    size_hint_x: 0.5
                                Label:
                                    text: str(int(root.tgt_na))
                                    size_hint_x: 0.2
                                    font_size: '14sp'

                    # --- BOTTOM SECTION (PINNED - DO NOT TOUCH) ---
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: 0.5
                        spacing: 0
                        padding: 0

                        # 1. TOP SPACER (Locks Sulfate Position)
                        Widget:
                            size_hint_y: None
                            height: '100dp'

                        # 2. Sulfate (SO4)
                        BoxLayout:
                            size_hint_y: None
                            height: '40dp'
                            Label: 
                                text: "Sulfate (SO4)"
                                size_hint_x: 0.25
                                halign: 'right'
                                valign: 'middle'
                                padding_x: 10
                                color: 0.2, 0.8, 0.8, 1
                            Slider:
                                min: 0
                                max: 350
                                step: 5
                                value: root.tgt_so4
                                on_value: root.tgt_so4 = self.value
                                size_hint_x: 0.65
                            Label:
                                text: str(int(root.tgt_so4))
                                size_hint_x: 0.1
                                bold: True

                        # 3. MIDDLE SPACER (Locks Chloride Position)
                        Widget:
                            size_hint_y: None
                            height: '20dp'

                        # 4. Chloride (Cl)
                        BoxLayout:
                            size_hint_y: None
                            height: '40dp'
                            Label: 
                                text: "Chloride (Cl)"
                                size_hint_x: 0.25
                                halign: 'right'
                                valign: 'middle'
                                padding_x: 10
                                color: 0.8, 0.4, 0.2, 1
                            Slider:
                                min: 0
                                max: 350
                                step: 5
                                value: root.tgt_cl
                                on_value: root.tgt_cl = self.value
                                size_hint_x: 0.65
                            Label:
                                text: str(int(root.tgt_cl))
                                size_hint_x: 0.1
                                bold: True
                        
                        # 5. BOTTOM FILLER
                        Widget:

            # --- TAB 3: RESULTS ---
            TabbedPanelItem:
                id: tab_results
                text: "RESULTS"
                BoxLayout:
                    orientation: 'vertical'
                    padding: 10
                    spacing: 5
                    
                    GridLayout:
                        cols: 2
                        spacing: 10
                        
                        # --- COLUMN 0: WATER REQUIREMENTS (Optimized) ---
                        BoxLayout:
                            orientation: 'vertical'
                            spacing: 5
                            canvas.before:
                                Color: 
                                    rgba: 0.15, 0.15, 0.15, 1
                                Rectangle: 
                                    pos: self.pos
                                    size: self.size
                            
                            # Title
                            Label:
                                text: "Water Requirements"
                                size_hint_y: None
                                height: '35dp'
                                bold: True
                                color: 0.2, 0.6, 1, 1
                                font_size: '18sp'
                                canvas.before:
                                    Color:
                                        rgba: 0.1, 0.1, 0.1, 1
                                    Rectangle:
                                        pos: self.pos
                                        size: self.size

                            # DATA GRID
                            GridLayout:
                                cols: 2
                                spacing: 5
                                size_hint_y: None
                                height: self.minimum_height
                                
                                # ROW 1
                                ResultRow:
                                    title: "Strike"
                                    value: root.strike_vol
                                ResultRow:
                                    title: "Temp"
                                    value: root.strike_temp
                                    value_color: (1, 0.6, 0.2, 1)

                                # ROW 2
                                ResultRow:
                                    title: "Sparge"
                                    value: root.sparge_vol
                                Widget: # Spacer
                                    size_hint_y: None
                                    height: '30dp'

                                # ROW 3
                                ResultRow:
                                    title: "Pre-Boil"
                                    value: root.pre_boil_vol
                                Widget: # Spacer
                                    size_hint_y: None
                                    height: '30dp'

                            # SPACER
                            Widget: 

                            # BLUE WARNING BOX
                            BoxLayout:
                                orientation: 'vertical'
                                size_hint_y: None
                                height: '80dp'
                                padding: 5
                                canvas.before:
                                    Color:
                                        rgba: 0.1, 0.2, 0.4, 1 # Blue Background
                                    Rectangle:
                                        pos: self.pos
                                        size: self.size
                                
                                BoxLayout:
                                    Label:
                                        text: "Total Mash Volume"
                                        halign: 'left'
                                        text_size: self.size
                                        valign: 'middle'
                                        color: 0.7, 0.8, 1, 1
                                        font_size: '16sp'
                                    Label:
                                        text: root.total_mash_vol
                                        halign: 'right'
                                        text_size: self.size
                                        valign: 'middle'
                                        bold: True
                                        font_size: '18sp'
                                        color: 1, 1, 1, 1

                                Label:
                                    text: "Ensure your Mash Tun is large enough to hold the Total Mash Volume."
                                    text_size: self.width, None
                                    halign: 'left'
                                    valign: 'top'
                                    color: 0.8, 0.8, 0.8, 1
                                    font_size: '13sp'

                        # --- COLUMN 1: SALT ADDITIONS (Optimized) ---
                        BoxLayout:
                            orientation: 'vertical'
                            spacing: 5
                            canvas.before:
                                Color: 
                                    rgba: 0.15, 0.15, 0.15, 1
                                Rectangle: 
                                    pos: self.pos
                                    size: self.size

                            # Title
                            Label:
                                text: "Salt Additions"
                                size_hint_y: None
                                height: '35dp'
                                bold: True
                                color: 0.2, 0.8, 0.2, 1
                                font_size: '18sp'
                                canvas.before:
                                    Color:
                                        rgba: 0.1, 0.1, 0.1, 1
                                    Rectangle:
                                        pos: self.pos
                                        size: self.size

                            # DATA GRID
                            GridLayout:
                                cols: 2
                                spacing: 5
                                size_hint_y: None
                                height: self.minimum_height
                                
                                # ROW 1
                                ResultRow:
                                    title: "Gypsum"
                                    value: root.res_gypsum
                                ResultRow:
                                    title: "Salt (NaCl)"
                                    value: root.res_salt

                                # ROW 2
                                ResultRow:
                                    title: "CaCl2"
                                    value: root.res_cacl2
                                ResultRow:
                                    title: "Lime"
                                    value: root.res_lime

                                # ROW 3
                                ResultRow:
                                    title: "Epsom"
                                    value: root.res_epsom
                                Widget:
                                    size_hint_y: None
                                    height: '30dp'

                            # SPACER
                            Widget:

                            # LACTIC ACID BOX
                            BoxLayout:
                                size_hint_y: None
                                height: '50dp'
                                padding: 10
                                canvas.before:
                                    Color:
                                        rgba: 0.25, 0.25, 0.25, 1 # Light Gray
                                    Rectangle:
                                        pos: self.pos
                                        size: self.size
                                Label:
                                    text: "Lactic Acid (88%)"
                                    text_size: self.size
                                    halign: 'left'
                                    valign: 'middle'
                                    color: 0.6, 0.6, 0.6, 1
                                    font_size: '16sp'
                                Label:
                                    text: root.res_acid + " / " + root.res_acid_g
                                    text_size: self.size
                                    halign: 'right'
                                    valign: 'middle'
                                    bold: True
                                    font_size: '18sp'
                                    color: 1, 0.2, 0.2, 1 # Red Text

                    # Footer Buttons (Split)
                    BoxLayout:
                        size_hint_y: None
                        height: '50dp'
                        spacing: 20
                        
                        Button:
                            text: "CALCULATE"
                            background_color: 0.2, 0.8, 0.2, 1
                            bold: True
                            on_release: root.calculate_all()

                        Button:
                            text: "EXIT APP"
                            background_color: 0.8, 0.2, 0.2, 1
                            bold: True
                            on_release: root.exit_app()

# --- HELPER WIDGET FOR RESULTS ---
<ResultRow@BoxLayout>:
    title: ""
    value: ""
    value_color: (1, 1, 1, 1)
    size_hint_y: None
    height: '30dp'
    Label:
        text: root.title
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        padding_x: 10
        color: 0.7, 0.7, 0.7, 1
    Label:
        text: root.value
        text_size: self.size
        halign: 'right'
        valign: 'middle'
        padding_x: 10
        bold: True
        color: root.value_color
